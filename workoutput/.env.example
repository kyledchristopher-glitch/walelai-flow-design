# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (server only, never expose to the client)
ANTHROPIC_API_KEY=
MODEL_PRIMARY=claude-sonnet-4-6
MODEL_FAST=claude-haiku-4-5-20251001

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Preview password protection
# Vercel deployments require this by default. Set PASSWORD_PROTECTION=false only
# after you intentionally want the deployment to become publicly reachable.
PASSWORD_PROTECTION=true
PASSWORD_PROTECTION_USERNAME=
PASSWORD_PROTECTION_PASSWORD=
